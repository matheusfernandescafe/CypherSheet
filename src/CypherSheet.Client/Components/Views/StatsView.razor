@using CypherSheet.Domain
@using CypherSheet.Storage
@using CypherSheet.Client.Components.Shared
@using CypherSheet.Client.Components.Dialogs
@using CypherSheet.Client.Services
@inject ICharacterRepository Repository
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IImageCacheService ImageCacheService

@if (Character == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudStack Spacing="2">
        <MudCard Elevation="3">
            <MudCardContent>
                <div class="character-header">
                    <div class="character-image-section">
                        <LazyCharacterImage CharacterId="@Character.Id"
                                          CharacterName="@Character.Name" 
                                          Size="ImageDisplaySize.Large"
                                          AvatarColor="Color.Primary"
                                          OnImageClick="@OpenImageModal" />
                    </div>
                    <div class="character-info">
                        <div class="character-name" @onclick="OnNameClick" style="cursor: pointer;">
                            <MudText Typo="Typo.h4">@Character.Name</MudText>
                        </div>
                        <div class="character-description" @onclick="OnDescriptionClick" style="cursor: pointer;">
                            <div class="descriptor-type-line">
                                <MudText Typo="Typo.body1">é um @Character.Descriptor @Character.Type</MudText>
                            </div>
                            <div class="focus-line">
                                <MudText Typo="Typo.body1">que @Character.Focus</MudText>
                            </div>
                        </div>
                        <div class="character-stats">
                            <div class="tier-info" @onclick="OnTierClick" style="cursor: pointer;">
                                <MudText Typo="Typo.body2">Tier @Character.Tier</MudText>
                            </div>
                            <div class="xp-info">
                                <MudButton Variant="Variant.Text" 
                                         Color="Color.Primary" 
                                         Size="Size.Small"
                                         OnClick="OnXPClick"
                                         Class="pa-1">
                                    XP: @Character.XP
                                </MudButton>
                            </div>
                        </div>
                    </div>
                </div>
            </MudCardContent>
        </MudCard>

        <PoolComponent Pool="@Character.Might" OnChange="SaveCharacter" />
        <PoolComponent Pool="@Character.Speed" OnChange="SaveCharacter" />
        <PoolComponent Pool="@Character.Intellect" OnChange="SaveCharacter" />
        
        <MudCard Elevation="3" Class="pa-2">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">Recovery</MudText>
                
                <!-- Sequential Recovery Stepper -->
                <div class="d-flex justify-space-between align-center mb-3" style="gap: 4px;">
                    @foreach (var step in _allSteps)
                    {
                        var isUsed = Character.Recovery.IsStepUsed(step);
                        var isNext = Character.Recovery.GetNextStep() == step;
                        <MudPaper Elevation="@(isNext ? 3 : 0)" 
                                  Class="@($"pa-2 flex-grow-1 d-flex flex-column align-center justify-center")"
                                  Style="@GetStepStyle(step, isUsed, isNext)">
                            @if (isUsed)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                            else if (isNext)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ArrowCircleRight" Color="Color.Primary" Size="Size.Small" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Circle" Size="Size.Small" 
                                         Style="opacity: 0.35;" />
                            }
                            <MudText Typo="Typo.caption" Align="Align.Center" 
                                     Style="@($"font-size: 0.65rem; line-height: 1.2; margin-top: 2px; {(isUsed ? "opacity: 0.6;" : isNext ? "font-weight: 600;" : "opacity: 0.35;")}")">
                                @Recovery.GetStepShortLabel(step)
                            </MudText>
                        </MudPaper>
                    }
                </div>

                <!-- Action Buttons -->
                <MudStack Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Casino"
                               Disabled="@Character.Recovery.AllUsed"
                               OnClick="OnFazerRecovery">
                        @if (Character.Recovery.AllUsed)
                        {
                            <span>Todas as Recoveries Usadas</span>
                        }
                        else
                        {
                            <span>Fazer Recovery — @Recovery.GetStepLabel(Character.Recovery.GetNextStep()!.Value)</span>
                        }
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Brightness7"
                               Disabled="@(Character.Recovery.CompletedCount == 0)"
                               OnClick="OnFimDeDia">
                        Fim de Dia
                    </MudButton>
                </MudStack>

                <!-- Custom Roll Bonus Field -->
                <div class="d-flex align-center gap-2 mt-3">
                    <MudText Typo="Typo.body1" Style="white-space: nowrap;">1D6 +</MudText>
                    <MudNumericField @bind-Value="Character.Recovery.CustomRollBonus" 
                                   Variant="Variant.Outlined" 
                                   Min="0" 
                                   T="int" 
                                   OnBlur="SaveCharacter" 
                                   Placeholder="0"
                                   Style="width: 60px;" />
                </div>
            </MudCardContent>
        </MudCard>


        <MudCard Elevation="3" Class="pa-2">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-2">Atributos Adicionais</MudText>
                <MudStack Row="true" Spacing="2">
                    <MudNumericField @bind-Value="Character.Effort" Label="Effort" Variant="Variant.Outlined" Min="0" T="int" OnBlur="SaveCharacter" FullWidth="true" />
                    <MudNumericField @bind-Value="Character.Armor" Label="Armor" Variant="Variant.Outlined" Min="0" T="int" OnBlur="SaveCharacter" FullWidth="true" />
                </MudStack>
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="3" Class="pa-3">
            <MudCardContent>
                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText Typo="Typo.h6">Marcador de Dano</MudText>
                    <MudChip T="string" Color="@GetDamageTrackColor()" Size="Size.Small" Variant="Variant.Filled">
                        @GetDamageTrackLabel()
                    </MudChip>
                </div>

                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <MudCheckBox Value="@Character.Impaired" Label="Enfraquecido" Dense="true" Color="Color.Warning" T="bool"
                                     Disabled="@IsImpairedFromPools()" ReadOnly="@IsImpairedFromPools()"
                                     ValueChanged="@((v) => UpdateDamageTrack(v, true))" />
                        @if (IsImpairedFromPools() && !Character.ImpairedOverride)
                        {
                            <MudText Typo="Typo.caption" Class="ml-8" Color="Color.Warning">
                                <em>(automático — pool a zero)</em>
                            </MudText>
                        }
                        <MudText Typo="Typo.caption" Class="ml-8">
                            +1 de Esforço por nível aplicado<br/>
                            Ignora efeitos menores e maiores nas rolagens<br/>
                            Rolagem de combate 17-20 causa apenas +1 de dano
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudCheckBox Value="@Character.Debilitated" Label="Debilitado" Dense="true" Color="Color.Error" T="bool"
                                     Disabled="@IsDebilitatedFromPools()" ReadOnly="@IsDebilitatedFromPools()"
                                     ValueChanged="@((v) => UpdateDamageTrack(v, false))" />
                        @if (IsDebilitatedFromPools() && !Character.DebilitatedOverride)
                        {
                            <MudText Typo="Typo.caption" Class="ml-8" Color="Color.Error">
                                <em>(automático — 2+ pools a zero)</em>
                            </MudText>
                        }
                        <MudText Typo="Typo.caption" Class="ml-8">
                            Pode mover-se apenas uma distância imediata<br/>
                            Não pode se mover se o Pool de Speed for 0
                        </MudText>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

    </MudStack>
}

@code {
    [Parameter] public Character Character { get; set; } = null!;
    [Parameter] public EventCallback<Character> CharacterChanged { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }



    private async Task EditStats()
    {
        var parameters = new DialogParameters { ["Character"] = Character };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<EditCharacterDialog>("Editar Personagem", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await SaveCharacter();
        }
    }

    // New event handlers for character header interactions
    private async Task OnNameClick()
    {
        await EditStats();
    }

    private async Task OnDescriptionClick()
    {
        await EditStats();
    }

    private async Task OnTierClick()
    {
        await EditStats();
    }

    private async Task OnXPClick()
    {
        await OpenXPDialog();
    }

    private async Task SaveCharacter()
    {
        await OnSave.InvokeAsync();
    }
    // All recovery steps in sequential order, used by the stepper UI
    private static readonly RecoveryStep[] _allSteps = new[]
    {
        RecoveryStep.OneAction,
        RecoveryStep.TenMinutes,
        RecoveryStep.OneHour,
        RecoveryStep.TenHours
    };

    private async Task OnFazerRecovery()
    {
        var nextStep = Character.Recovery.GetNextStep();
        if (nextStep == null) return;

        var parameters = new DialogParameters 
        { 
            ["Character"] = Character,
            ["CurrentStep"] = nextStep.Value
        };
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true, 
            MaxWidth = MaxWidth.Small, 
            FullWidth = true 
        };
        
        var dialog = await DialogService.ShowAsync<RecoveryDialog>(
            $"Recovery — {Recovery.GetStepLabel(nextStep.Value)}", 
            parameters, 
            options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var pointsRecovered = (int)result.Data;
            Snackbar.Add(
                $"Recuperou {pointsRecovered} pontos ({Recovery.GetStepLabel(nextStep.Value)})", 
                Severity.Success);
            await SaveCharacter();
        }
        
        StateHasChanged();
    }

    private async Task OnFimDeDia()
    {
        Character.Recovery.Reset();

        // Also restore all pools to max
        Character.Might.Current = Character.Might.Max;
        Character.Speed.Current = Character.Speed.Max;
        Character.Intellect.Current = Character.Intellect.Max;

        // Clear manual damage overrides
        Character.ImpairedOverride = false;
        Character.DebilitatedOverride = false;

        Snackbar.Add("Fim de dia! Todas as pools e recoveries foram restauradas.", Severity.Info);
        await SaveCharacter();
        StateHasChanged();
    }

    private string GetStepStyle(RecoveryStep step, bool isUsed, bool isNext)
    {
        var baseStyle = "border-radius: 8px; min-height: 52px; transition: all 0.2s ease;";
        
        if (isUsed)
            return $"{baseStyle} background: rgba(var(--mud-palette-success-rgb), 0.1); border: 1px solid rgba(var(--mud-palette-success-rgb), 0.3);";
        if (isNext)
            return $"{baseStyle} background: rgba(var(--mud-palette-primary-rgb), 0.1); border: 2px solid rgba(var(--mud-palette-primary-rgb), 0.5);";
        
        return $"{baseStyle} background: transparent; border: 1px solid rgba(128,128,128,0.15);";
    }
    
    
    
    private async Task UpdateDamageTrack(bool value, bool isImpaired)
    {
        // Checkboxes now toggle the manual override flags, not the computed properties.
        if (isImpaired)
        {
            Character.ImpairedOverride = value;
        }
        else
        {
            Character.DebilitatedOverride = value;
        }
        await SaveCharacter();
    }

    /// <summary>
    /// True when the pool-based damage track already makes the character Impaired
    /// (i.e. at least 1 pool is at zero). In this case the checkbox is disabled
    /// because the condition is automatic.
    /// </summary>
    private bool IsImpairedFromPools() => Character.GetDamageTrack() >= DamageTrack.Impaired;

    /// <summary>
    /// True when the pool-based damage track already makes the character Debilitated
    /// (i.e. at least 2 pools are at zero).
    /// </summary>
    private bool IsDebilitatedFromPools() => Character.GetDamageTrack() >= DamageTrack.Debilitated;

    private Color GetDamageTrackColor()
    {
        return Character.GetEffectiveDamageTrack() switch
        {
            DamageTrack.Hale => Color.Success,
            DamageTrack.Impaired => Color.Warning,
            DamageTrack.Debilitated => Color.Error,
            DamageTrack.Dead => Color.Dark,
            _ => Color.Default
        };
    }

    private string GetDamageTrackLabel()
    {
        return Character.GetEffectiveDamageTrack() switch
        {
            DamageTrack.Hale => "Saudável",
            DamageTrack.Impaired => "Enfraquecido",
            DamageTrack.Debilitated => "Debilitado",
            DamageTrack.Dead => "Morto",
            _ => "—"
        };
    }
    
    private async Task OpenXPDialog()
    {
        var parameters = new DialogParameters { ["Character"] = Character };
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true, 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseButton = true
        };
        
        var dialog = await DialogService.ShowAsync<XPDialog>("Gerenciar XP", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await SaveCharacter();
            StateHasChanged();
        }
    }

    private async Task OpenImageModal()
    {
        // Verificar se o personagem tem imagem válida
        if (Character?.Id == null) return;
        
        try
        {
            var imageData = await ImageCacheService.GetImageAsync(Character.Id);
            if (imageData == null || imageData.Length == 0) return;
            
            var parameters = new DialogParameters 
            { 
                ["ImageData"] = imageData,
                ["CharacterName"] = Character.Name
            };
            
            var options = new DialogOptions 
            { 
                CloseOnEscapeKey = true,
                MaxWidth = MaxWidth.Large,
                FullWidth = true,
                CloseButton = false
            };
            
            await DialogService.ShowAsync<CharacterImageModal>("", parameters, options);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao abrir modal de imagem: {ex.Message}");
            Snackbar.Add("Não foi possível carregar a imagem", Severity.Warning);
        }
    }
}
