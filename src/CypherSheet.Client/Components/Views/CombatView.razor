@using CypherSheet.Domain
@using CypherSheet.Client.Components.Views
@using CypherSheet.Client.Pages
@inject CypherSheet.Client.Services.CharacterStateService StateService
@inject ISnackbar Snackbar

@if (StateService.Character == null)
{
    <MudContainer Class="d-flex justify-center align-center pa-4">
        <MudAlert Severity="Severity.Info">
            Selecione um personagem para acessar funcionalidades de combate.
        </MudAlert>
    </MudContainer>
}
else
{
    @switch (_currentSubView)
    {
        case CombatSubView.None:
            <MudStack Spacing="2" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">Combat</MudText>
                <MudStack Spacing="2">

                    @* Iniciativas — ActiveButton *@
                    <MudPaper Elevation="1" Class="active-nav-button" Style="min-height: 72px; width: 100%; cursor: pointer;" @onclick="@(() => NavigateTo(CombatSubView.InitiativeTracker))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="pa-3" Style="min-height: 72px;">
                            <div style="width: 40px; height: 40px; border-radius: 8px; background-color: var(--mud-palette-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <MudIcon Icon="@Icons.Material.Filled.FormatListNumbered" Color="Color.Surface" />
                            </div>
                            <MudText Typo="Typo.h6" Style="align-self: center;">Iniciativas</MudText>
                        </MudStack>
                    </MudPaper>

                    @* Bônus e Penalidades — ActiveButton *@
                    <MudPaper Elevation="1" Class="active-nav-button" Style="min-height: 72px; width: 100%; cursor: pointer;" @onclick="@(() => NavigateTo(CombatSubView.BonusesAndPenalties))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="pa-3" Style="min-height: 72px;">
                            <div style="width: 40px; height: 40px; border-radius: 8px; background-color: var(--mud-palette-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Surface" />
                            </div>
                            <MudText Typo="Typo.h6" Style="align-self: center;">Bônus e Penalidades</MudText>
                        </MudStack>
                    </MudPaper>

                    @* Calculadora de Rolagem — ActiveButton *@
                    <MudPaper Elevation="1" Class="active-nav-button" Style="min-height: 72px; width: 100%; cursor: pointer;" @onclick="@(() => NavigateTo(CombatSubView.RollCalculator))">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="pa-3" Style="min-height: 72px;">
                            <div style="width: 40px; height: 40px; border-radius: 8px; background-color: var(--mud-palette-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <MudIcon Icon="@Icons.Material.Filled.Calculate" Color="Color.Surface" />
                            </div>
                            <MudText Typo="Typo.h6" Style="align-self: center;">Calculadora de Rolagem</MudText>
                        </MudStack>
                    </MudPaper>

                    @* Rolagem de Dados — DisabledButton (funcionalidade futura) *@
                    <MudPaper Elevation="1" Style="min-height: 72px; width: 100%; opacity: 0.4; cursor: default;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="pa-3" Style="min-height: 72px;">
                            <div style="width: 40px; height: 40px; border-radius: 8px; background-color: var(--mud-palette-primary); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <MudIcon Icon="@Icons.Material.Filled.Casino" Color="Color.Surface" />
                            </div>
                            <MudText Typo="Typo.h6" Style="align-self: center;">Rolagem de Dados</MudText>
                        </MudStack>
                    </MudPaper>

                </MudStack>
            </MudStack>
            break;

        case CombatSubView.BonusesAndPenalties:
            <MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
                <EffectsManager />
            </MudStack>
            break;

        case CombatSubView.RollCalculator:
            <MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
                <RollCalculatorComponent OnApplied="@GoBack" />
            </MudStack>
            break;

        case CombatSubView.InitiativeTracker:
            <MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
                <InitiativeTrackerView />
            </MudStack>
            break;

        default:
            // Salvaguarda: estado inválido retorna para None
            _currentSubView = CombatSubView.None;
            break;
    }
}

@code {
    [Parameter] public int ResetKey { get; set; }

    private CombatSubView _currentSubView = CombatSubView.None;
    private int _previousResetKey;

    protected override void OnParametersSet()
    {
        if (ResetKey != _previousResetKey)
        {
            _previousResetKey = ResetKey;
            _currentSubView = CombatSubView.None;
        }
    }

    private void NavigateTo(CombatSubView subView)
    {
        _currentSubView = subView;
    }

    private void GoBack()
    {
        _currentSubView = CombatSubView.None;
    }
}
