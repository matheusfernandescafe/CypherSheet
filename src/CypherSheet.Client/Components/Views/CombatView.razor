@using CypherSheet.Domain
@using CypherSheet.Client.Components.Views
@inject CypherSheet.Client.Services.CharacterStateService StateService
@inject ISnackbar Snackbar

@if (StateService.Character == null)
{
    <MudContainer Class="d-flex justify-center align-center pa-4">
        <MudAlert Severity="Severity.Info">
            Selecione um personagem para acessar funcionalidades de combate.
        </MudAlert>
    </MudContainer>
}
else
{
    <!-- BuffsDebuffsArea placeholder -->
    <MudCard Elevation="0" Class="mb-2" Style="opacity: 0.5;">
        <MudCardContent Class="py-2">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                <MudIcon Icon="@Icons.Material.Outlined.AutoFixHigh" Size="Size.Small" Class="mr-1" />
                Buffs &amp; Debuffs temporários — em breve
            </MudText>
        </MudCardContent>
    </MudCard>

    <RollCalculatorComponent />
}

@code {
    private Character Character => StateService.Character!;
}
