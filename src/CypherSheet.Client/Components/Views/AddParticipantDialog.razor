@using CypherSheet.Domain
@using MudBlazor

<MudDialog>
    <DialogContent>

        <MudTextField @bind-Value="name"
                      Label="Nome do Participante"
                      Required="true"
                      AutoFocus="true"
                      Immediate="true"
                      Error="@IsNameInvalid"
                      ErrorText="O nome não pode ser vazio."
                      Class="mb-4" />

        <MudNumericField T="int?"
                         @bind-Value="initiativeValue"
                         Label="Valor de Iniciativa"
                         Required="true"
                         Immediate="true"
                         Class="mb-2" />

    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@IsSubmitDisabled"
                   OnClick="Submit">
            Adicionar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;

    private string name = string.Empty;
    private int? initiativeValue = null;

    private bool IsNameInvalid => name.Length > 0 && string.IsNullOrWhiteSpace(name);

    private bool IsSubmitDisabled =>
        string.IsNullOrWhiteSpace(name) ||
        initiativeValue is null;

    private void Submit()
    {
        if (IsSubmitDisabled) return;

        var participant = new InitiativeParticipant
        {
            Name = name.Trim(),
            InitiativeValue = initiativeValue!.Value
        };

        MudDialog.Close(DialogResult.Ok(participant));
    }

    private void Cancel() => MudDialog.Cancel();
}
