@inject CypherSheet.Client.Services.CharacterStateService StateService
@implements IDisposable

<div class="sidebar-navigation">
    <div class="sidebar-item @(CurrentTab == TabType.Stats ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Stats))">
        <MudIcon Icon="@Icons.Material.Filled.Person" />
        <span class="sidebar-item-label">Stats</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Combat ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Combat))">
        <MudIcon Icon="@Icons.Material.Filled.Gavel" />
        <span class="sidebar-item-label">Combat</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Skills ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Skills))">
        <MudIcon Icon="@Icons.Material.Filled.SportsMma" />
        <span class="sidebar-item-label">Skills</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Abilities ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Abilities))">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" />
        <span class="sidebar-item-label">Abilities</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Cyphers ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Cyphers))">
        <MudIcon Icon="@Icons.Material.Filled.ChangeHistory" />
        <span class="sidebar-item-label">Cyphers</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Equipment ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Equipment))">
        <MudIcon Icon="@Icons.Material.Filled.Backpack" />
        <span class="sidebar-item-label">Equipment</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Notes ? "active" : "") @(!IsCharacterLoaded ? "disabled" : "")"
         @onclick="@(() => OnTabClick(TabType.Notes))">
        <MudIcon Icon="@Icons.Material.Filled.EditNote" />
        <span class="sidebar-item-label">Notes</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Characters ? "active" : "")"
         @onclick="@(() => OnTabClick(TabType.Characters))">
        <MudIcon Icon="@Icons.Material.Filled.Groups" />
        <span class="sidebar-item-label">Characters</span>
    </div>

    <div class="sidebar-item @(CurrentTab == TabType.Settings ? "active" : "")"
         @onclick="@(() => OnTabClick(TabType.Settings))">
        <MudIcon Icon="@Icons.Material.Filled.Settings" />
        <span class="sidebar-item-label">Settings</span>
    </div>
</div>

@code {
    [Parameter] public TabType CurrentTab { get; set; }
    [Parameter] public EventCallback<TabType> CurrentTabChanged { get; set; }

    private bool IsCharacterLoaded => StateService.Character != null;

    protected override void OnInitialized()
    {
        StateService.OnChange += OnStateChanged;
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StateService.OnChange -= OnStateChanged;
    }

    private async Task OnTabClick(TabType tab)
    {
        // Itens de personagem ficam desabilitados quando não há personagem carregado
        bool isCharacterTab = tab != TabType.Characters && tab != TabType.Settings;
        if (isCharacterTab && !IsCharacterLoaded)
        {
            return;
        }

        await CurrentTabChanged.InvokeAsync(tab);
    }
}
