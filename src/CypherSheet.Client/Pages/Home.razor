@page "/character/{Id:guid}"
@using CypherSheet.Domain
@using CypherSheet.Storage
@using CypherSheet.Client.Components.Views
@inject CypherSheet.Client.Services.CharacterStateService StateService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(StateService.Character?.Name ?? "Carregando...") - Cypher Sheet</PageTitle>

<div class="app-container">
    <div class="content-area">
        @if (isLoading)
        {
            <MudContainer Class="d-flex justify-center align-center" Style="height: 100vh;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </MudContainer>
        }
        else if (StateService.Character == null)
        {
            @switch (currentTab)
            {
                case TabType.Characters:
                    <div class="d-flex justify-center align-center pa-4">
                        <MudStack Spacing="3" AlignItems="AlignItems.Center">
                            <MudAlert Severity="Severity.Info">Personagem não encontrado.</MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo(""))">Selecionar Personagem</MudButton>
                        </MudStack>
                    </div>
                    break;
                case TabType.Settings:
                default:
                    <SettingsView />
                    break;
            }
        }
        else
        {
            @switch (currentTab)
            {
                case TabType.Stats:
                    <StatsView />
                    break;
                case TabType.Combat:
                    <CombatView />
                    break;
                case TabType.Skills:
                    <SkillsView />
                    break;
                case TabType.Abilities:
                    <AbilitiesView />
                    break;
                case TabType.Cyphers:
                    <CyphersView />
                    break;
                case TabType.Equipment:
                    <EquipmentView />
                    break;
                case TabType.Notes:
                    <NotesView />
                    break;
                case TabType.Characters:
                    <div class="d-flex justify-center align-center pa-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo(""))">Trocar Personagem</MudButton>
                    </div>
                    break;
                case TabType.Settings:
                    <SettingsView />
                    break;
            }
        }
    </div>

    <AppFooter CurrentTab="currentTab" CurrentTabChanged="NavigateToTab" />
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private bool isLoading = true;

    private TabType currentTab = TabType.Stats;

    protected override async Task OnInitializedAsync()
    {
        StateService.OnChange += StateHasChanged;
        isLoading = true;
        await StateService.LoadCharacterAsync(Id);

        // Se não há personagem, definir Settings como aba padrão
        if (StateService.Character == null)
        {
            currentTab = TabType.Settings;
        }

        isLoading = false;
    }

    public void Dispose()
    {
        StateService.OnChange -= StateHasChanged;
    }

    private void NavigateToTab(TabType tab)
    {
        currentTab = tab;
    }
}
