@page "/"
@using CypherSheet.Client.Components.Views
@using CypherSheet.Client.Services
@inject NavigationStateService NavigationStateService
@implements IDisposable

<PageTitle>Meus Personagens - Cypher Sheet</PageTitle>

@switch (NavigationStateService.CurrentTab)
{
    case TabType.Characters:
    default:
        <CharacterListView />
        break;
    case TabType.Settings:
        <SettingsView />
        break;
}

@code {
    protected override void OnInitialized()
    {
        NavigationStateService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        NavigationStateService.OnChange -= StateHasChanged;
    }
}
